<?xml version="1.0"?>
        <robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="ctr">
          <xacro:property name="outer_length" value="0.030000"/>
          <xacro:property name="inner_length" value="0.030000"/>
          <xacro:property name="outer_inner_diameter" value="0.004000"/>
          <xacro:property name="outer_outer_diameter" value="0.005000"/>
          <xacro:property name="inner_inner_diameter" value="0.003100"/>
          <xacro:property name="inner_outer_diameter" value="0.003600"/>
